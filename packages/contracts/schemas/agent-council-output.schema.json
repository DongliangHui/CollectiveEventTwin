{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collective-event-twin.local/schemas/agent-council-output.schema.json",
  "title": "AgentCouncilOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "stance",
    "reaction",
    "support_point_delta",
    "branch_probability_delta",
    "evidence_refs",
    "uncertainty",
    "blocked_claims"
  ],
  "properties": {
    "role": { "type": "string", "minLength": 1 },
    "stance": { "type": "string", "minLength": 1 },
    "reaction": { "type": "string", "minLength": 1 },
    "support_point_delta": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": -1, "maximum": 1 }
    },
    "branch_probability_delta": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": -1, "maximum": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "uncertainty": { "type": "string", "minLength": 1 },
    "blocked_claims": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
